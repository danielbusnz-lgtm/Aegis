{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aegis Settings",
  "version": "0.1.0",
  "identifier": "com.aegis.settings",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Aegis",
        "width": 600,
        "height": 350,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
